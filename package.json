    "keybindings": [
      {
        "command": "extension.replaceTranslateSelectedText",
        "key": "alt+shift+t",
        "mac": "alt+shift+t",
        "when": "editorTextFocus",
        "description": "%keybinding.replaceTranslateSelectedText.description%"
      },
      {
        "command": "extension.setTargetLanguage",
        "key": "ctrl+alt+shift+l",
        "mac": "cmd+alt+shift+l",
        "when": "editorTextFocus",
        "description": "%keybinding.setTargetLanguage.description%"
      },
      {
        "command": "extension.setDefaultEngine",
