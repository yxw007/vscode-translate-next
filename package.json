        "mac": "alt+shift+e",
        "when": "editorTextFocus",
        "description": "%keybinding.setDefaultEngine.description%"
      },
      {
        "command": "extension.openOutputPanel",
        "key": "ctrl+alt+shift+o",
        "mac": "command+alt+shift+o",
        "when": "editorTextFocus || terminalFocus",
        "description": "%keybinding.openOutputPanel.description%"
      },
      {
        "command": "extension.clearOutputPanel",
        "key": "ctrl+alt+c",
        "mac": "command+alt+c",
        "when": "editorTextFocus",
        "description": "%keybinding.clearOutputPanel.description%"
      },
      {
        "command": "extension.openTerminalTranslateView",
        "key": "alt+shift+o",
        "mac": "alt+shift+o",
        "when": "editorTextFocus || terminalFocus",
        "description": "%keybinding.openTerminalTranslateView.description%"
      },
      {
        "command": "extension.translateTerminalText",
        "key": "ctrl+alt+`",
        "mac": "command+alt+`",
        "when": "terminalFocus",
        "description": "%keybinding.translateTerminalText.description%"
      },
      {
        "command": "extension.clearTerminalTranslateLogs",
        "key": "alt+c",
        "mac": "alt+c",
        "when": "editorTextFocus || terminalFocus",
        "description": "%keybinding.clearTerminalTranslateLogs.description%"
      },
      {
        "command": "extension.languageDetectToggle",
        "key": "ctrl+alt+t",
        "mac": "command+alt+t",
        "when": "editorTextFocus || terminalFocus",
        "description": "%keybinding.languageDetectToggle.description%"
      },
      {
        "command": "extension.hover.enable",
        "key": "ctrl+alt+e",
        "mac": "cmd+alt+e",
        "when": "editorTextFocus",
        "description": "%keybinding.hover.enable.description%"
      }
