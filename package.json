{
  "name": "vscode-translate-next",
  "version": "0.0.1",
  "displayName": "vscode-translate-next",
  "author": {
    "name": "Potter",
    "email": "aa4790139@gmail.com"
  },
  "description": "A translate vscode extension that supports multiple translation engines",
  "homepage": "https://github.com/yxw007/vscode-translate-next",
  "repository": {
    "type": "git",
    "url": "https://github.com/yxw007/vscode-translate-next.git"
  },
  "bugs": {
    "url": "https://github.com/yxw007/vscode-translate-next/issues"
  },
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "vscode",
    "extension",
    "translate",
    "i18n",
    "localization",
    "internationalization",
    "language",
    "google",
    "azure translator",
    "amazon translate",
    "baidu"
  ],
  "license": "MIT",
  "activationEvents": [],
  "main": "./dist/extension.js",
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test",
    "prepare": "husky"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "**/*.{ts}": [
      "pnpm lint"
    ]
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^19.4.1",
    "@types/mocha": "^10.0.7",
    "@types/node": "20.x",
    "@types/vscode": "^1.93.0",
    "@typescript-eslint/eslint-plugin": "^8.3.0",
    "@typescript-eslint/parser": "^8.3.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "changelogen": "^0.5.5",
    "commitlint": "^19.4.1",
    "esbuild": "^0.23.1",
    "eslint": "^9.9.1",
    "husky": "^9.1.5",
    "lint-staged": "^15.2.10",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@yxw007/translate": "^0.0.4"
  },
  "contributes": {
    "commands": [
      {
        "command": "extension.translateText",
        "title": "Translate selections"
      },
      {
        "command": "extension.setTargetLanguage",
        "title": "Set target language"
      }
    ],
    "configuration": {
      "title": "Translate-next",
      "properties": {
        "Translate-next.targetLanguage": {
          "type": "string",
          "enum": [
            "Afrikaans",
            "Albanian",
            "Amharic",
            "Arabic",
            "Armenian",
            "Azeerbaijani",
            "Basque",
            "Belarusian",
            "Bengali",
            "Bosnian",
            "Bulgarian",
            "Catalan",
            "Cebuano",
            "Chinese (Simplified)",
            "Chinese (Traditional)",
            "Corsican",
            "Croatian",
            "Czech",
            "Danish",
            "Dutch",
            "English",
            "Esperanto",
            "Estonian",
            "Finnish",
            "French",
            "Frisian",
            "Galician",
            "Georgian",
            "German",
            "Greek",
            "Gujarati",
            "Haitian Creole",
            "Hausa",
            "Hawaiian",
            "Hebrew",
            "Hindi",
            "Hmong",
            "Hungarian",
            "Icelandic",
            "Igbo",
            "Indonesian",
            "Irish",
            "Italian",
            "Japanese",
            "Javanese",
            "Kannada",
            "Kazakh",
            "Khmer",
            "Korean",
            "Kurdish",
            "Kyrgyz",
            "Lao",
            "Latin",
            "Latvian",
            "Lithuanian",
            "Luxembourgish",
            "Macedonian",
            "Malagasy",
            "Malay",
            "Malayalam",
            "Maltese",
            "Maori",
            "Marathi",
            "Mongolian",
            "Myanmar",
            "Nepali",
            "Norwegian",
            "Nyanja",
            "Pashto",
            "Persian",
            "Polish",
            "Portuguese",
            "Punjabi",
            "Romanian",
            "Russian",
            "Samoan",
            "Scots Gaelic",
            "Serbian",
            "Sesotho",
            "Shona",
            "Sindhi",
            "Sinhala",
            "Slovak",
            "Slovenian",
            "Somali",
            "Spanish",
            "Sundanese",
            "Swahili",
            "Swedish",
            "Tagalog",
            "Tajik",
            "Tamil",
            "Telugu",
            "Thai",
            "Turkish",
            "Ukrainian",
            "Urdu",
            "Uyghur",
            "Uzbek",
            "Vietnamese",
            "Welsh",
            "Xhosa",
            "Yiddish",
            "Yoruba",
            "Zulu"
          ],
          "default": "English",
          "description": "Change target language"
        },
        "Translate-next.defaultEngine": {
          "type": "string",
          "enum": [
            "google",
            "azure",
            "amazon",
            "baidu"
          ],
          "default": "google",
          "description": "The translation engine to use"
        },
        "Translate-next.azure.region": {
          "type": "string",
          "default": "your-region"
        },
        "Translate-next.azure.key": {
          "type": "string",
          "default": null
        },
        "Translate-next.amazon.region": {
          "type": "string",
          "default": "your-region"
        },
        "Translate-next.amazon.key_id": {
          "type": "string",
          "default": null
        },
        "Translate-next.amazon.access_key": {
          "type": "string",
          "default": null
        },
        "Translate-next.baidu.app_id": {
          "type": "string",
          "default": null
        },
        "Translate-next.baidu.secret_key": {
          "type": "string",
          "default": null
        }
      }
    }
  }
}
