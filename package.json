  "main": "./dist/extension.js",
  "l10n": "./l10n",
  "icon": "icon.png",
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "node -e \"require('fs').rmSync('out', { recursive: true, force: true })\" && tsc -p . --outDir out",
    "watch-tests": "node -e \"require('fs').rmSync('out', { recursive: true, force: true })\" && tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vscode-test",
    "build": "npx vsce package",
    "replace-contents": "node scripts/replace-contents.js",
    "pick-docs": "node scripts/pick-docs.js",
    "release": "npx changelogen --release -i && git push & git push --tags",
    "prepare": "husky"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "**/*.{ts}": [
      "npm lint"
    ]
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^19.5.0",
    "@types/marked": "^5.0.2",
    "@types/mocha": "^10.0.8",
    "@types/node": "~20.16.5",
    "@types/vscode": "^1.93.0",
    "@typescript-eslint/eslint-plugin": "^8.6.0",
    "@typescript-eslint/parser": "^8.6.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.7.1",
    "changelogen": "^0.5.7",
    "commitlint": "^19.5.0",
    "esbuild": "^0.23.1",
    "esbuild-plugin-copy": "^2.1.1",
    "esbuild-plugin-wasm": "^1.1.0",
    "eslint": "^9.10.0",
    "fs-extra": "^11.2.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.6.2"
  },
  "dependencies": {
    "@amplitude/analytics-node": "^1.3.6",
    "@yxw007/translate": "^1.0.1",
    "dayjs": "^1.11.21",
    "deepl-node": "^1.14.0",
    "entities": "^5.0.0",
    "humanize-string": "^3.0.0",
    "markdown-it": "^14.1.0",
    "onigasm": "^2.2.5",
    "remark-parse": "^9.0.0",
    "remark-stringify": "^9.0.1",
    "unified": "^9.2.2",
    "unist-util-visit": "^2.0.3",
    "uuid": "^11.0.3",
    "vscode-textmate": "^4.3.0"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "translateTerminalLogs",
          "title": "%view.container.translateTerminalLogs.title%",
          "icon": "icon.png"
        }
      ]
    },
    "views": {
      "translateTerminalLogs": [
        {
          "type": "webview",
          "id": "translateTerminalLogView",
          "name": "%view.translateTerminalLogView.name%",
          "icon": "icon.png"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "extension.sortTerminalTranslateLogsAsc",
          "when": "view == translateTerminalLogView",
          "group": "navigation"
        },
        {
          "command": "extension.sortTerminalTranslateLogsDesc",
          "when": "view == translateTerminalLogView",
          "group": "navigation"
        },
        {
          "command": "extension.clearTerminalTranslateLogs",
          "when": "view == translateTerminalLogView",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "extension.replaceTranslateSelectedText",
          "when": "editorTextFocus && editorHasSelection"
        },
        {
          "command": "extension.translateAllComments",
          "when": "editorTextFocus",
          "group": "1_translate@1"
        }
      ],
      "editor/title": [
        {
          "command": "extension.mdPreviewTranslate",
          "when": "resourceLangId == markdown",
          "group": "navigation"
        }
      ],
      "extension/context": [
        {
          "command": "extension.translateExtensionDetails",
          "group": "2_configure@50"
        }
      ]
    },
    "commands": [
      {
        "command": "extension.replaceTranslateSelectedText",
        "title": "%cmd.extension.replaceTranslateSelectedText.title%"
      },
      {
        "command": "extension.setTargetLanguage",
        "title": "%cmd.extension.setTargetLanguage.title%"
      },
      {
        "command": "extension.setParentLanguage",
        "title": "%cmd.extension.setParentLanguage.title%"
      },
      {
        "command": "extension.setDefaultEngine",
        "title": "%cmd.extension.setDefaultEngine.title%"
      },
      {
        "command": "extension.setDefaultLLM",
        "title": "%cmd.extension.setDefaultLLM.title%"
      },
      {
        "command": "extension.translateTerminalText",
        "title": "%cmd.extension.translateTerminalText.title%"
      },
      {
        "command": "extension.clearOutputPanel",
        "title": "%cmd.extension.clearOutputPanel.title%"
      },
      {
        "command": "extension.openTerminalTranslateView",
        "title": "%cmd.extension.openTerminalTranslateView.title%"
      },
      {
        "command": "extension.openOutputPanel",
        "title": "%cmd.extension.openOutputPanel.title%"
      },
      {
        "command": "extension.sortTerminalTranslateLogsAsc",
        "title": "%cmd.extension.sortTerminalTranslateLogsAsc.title%",
        "icon": "$(arrow-up)"
      },
      {
        "command": "extension.sortTerminalTranslateLogsDesc",
        "title": "%cmd.extension.sortTerminalTranslateLogsDesc.title%",
        "icon": "$(arrow-down)"
      },
      {
        "command": "extension.clearTerminalTranslateLogs",
        "title": "%cmd.extension.clearTerminalTranslateLogs.title%",
        "shortTitle": "%cmd.extension.clearTerminalTranslateLogs.shortTitle%",
        "icon": "$(trash)"
      },
      {
        "command": "extension.translateExtensionDetails",
        "title": "%cmd.extension.translateExtensionDetails.title%"
      },
      {
        "command": "extension.login",
        "title": "%cmd.extension.login.title%"
      },
      {
        "command": "extension.logout",
        "title": "%cmd.extension.logout.title%"
      },
      {
        "command": "extension.openPricing",
        "title": "%cmd.extension.openPricing.title%"
      },
      {
        "command": "extension.refreshLoginState",
        "title": "%cmd.extension.refreshLoginState.title%"
      },
      {
        "command": "extension.mdPreviewTranslate",
        "title": "%cmd.extension.mdPreviewTranslate.title%",
        "icon": "assets/images/md-preview.svg"
      },
      {
        "command": "extension.translateAllComments",
        "title": "%cmd.extension.translateAllComments.title%"
      }
    ],
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "Translate-next.targetLanguage": {
          "type": "string",
          "default": "English",
          "description": "%config.targetLanguage.description%",
          "order": 1
        },
        "Translate-next.defaultEngine": {
          "type": "string",
          "default": "google",
          "description": "%config.defaultEngine.description%",
          "order": 2
        },
        "Translate-next.authBaseUrl": {
          "type": "string",
          "default": "https://translate.yanxuewen.cn",
          "description": "%config.authBaseUrl.description%",
          "order": 2.05
        },
        "Translate-next.customEngines": {
          "type": "array",
          "default": [],
          "markdownDescription": "%config.customEngines.markdownDescription%",
          "order": 2.1,
          "defaultSnippets": [
            {
              "label": "%config.customEngines.defaultSnippets.label%",
              "body": [
                {
                  "enabled": true,
                  "name": "siliconflow-chat",
                  "apiUrl": "https://api.siliconflow.cn/v1/chat/completions",
                  "method": "POST",
                  "headers": {
                    "Authorization": "Bearer sk-xxxx",
                    "Content-Type": "application/json"
                  },
                  "body": {
                    "model": "Qwen/Qwen2.5-7B-Instruct",
                    "messages": [
                      {
                        "role": "user",
                        "content": "Translate the following text into English: {{text}}"
                      }
                    ]
                  },
                  "responsePath": "choices[0].message.content",
                  "fromLanguages": {
                    "Auto": "auto",
                    "English": "en",
                    "简体中文": "zh-CN"
                  },
                  "toLanguages": {
                    "English": "en",
                    "简体中文": "zh-CN",
                    "日本語": "ja"
                  },
                  "timeout": 30000
                }
              ]
            }
          ],
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "apiUrl",
              "toLanguages"
            ],
            "properties": {
              "enabled": {
                "type": "boolean",
                "default": true,
                "markdownDescription": "%config.customEngines.enabled.markdownDescription%"
              },
              "name": {
                "type": "string",
                "minLength": 1,
                "markdownDescription": "%config.customEngines.name.markdownDescription%"
              },
              "apiUrl": {
                "type": "string",
                "minLength": 1,
                "markdownDescription": "%config.customEngines.apiUrl.markdownDescription%"
              },
              "method": {
                "type": "string",
                "enum": [
                  "GET",
                  "POST"
                ],
                "default": "POST",
                "markdownDescription": "%config.customEngines.method.markdownDescription%"
              },
              "headers": {
                "type": "object",
                "default": {},
                "markdownDescription": "%config.customEngines.headers.markdownDescription%"
              },
              "query": {
                "type": "object",
                "default": {},
                "markdownDescription": "%config.customEngines.query.markdownDescription%"
              },
              "body": {
                "default": {},
                "markdownDescription": "%config.customEngines.body.markdownDescription%"
              },
              "responsePath": {
                "type": "string",
                "default": "",
                "markdownDescription": "%config.customEngines.responsePath.markdownDescription%"
              },
              "batchStrategy": {
                "type": "string",
                "enum": [
                  "none",
                  "join",
                  "array"
                ],
                "default": "none",
                "markdownDescription": "%config.customEngines.batchStrategy.markdownDescription%"
              },
              "joinDelimiter": {
                "type": "string",
                "default": "\n$TRANSLATE_NEXT_SPLIT$\n",
                "markdownDescription": "%config.customEngines.joinDelimiter.markdownDescription%"
              },
              "timeout": {
                "type": "number",
                "default": 30000,
                "minimum": 1,
                "markdownDescription": "%config.customEngines.timeout.markdownDescription%"
              },
              "fromLanguages": {
                "type": "object",
                "default": {
                  "Chinese": "zh",
                  "English": "en",
                  "Japanese": "ja",
                  "Korean": "ko"
                },
                "markdownDescription": "%config.customEngines.fromLanguages.markdownDescription%",
                "additionalProperties": {
                  "type": "string"
                }
              },
              "toLanguages": {
                "type": "object",
                "minProperties": 1,
                "default": {
                  "Chinese": "zh",
                  "English": "en",
                  "Japanese": "ja",
                  "Korean": "ko"
                },
                "markdownDescription": "%config.customEngines.toLanguages.markdownDescription%",
                "additionalProperties": {
                  "type": "string"
                }
              }
            }
          }
        },
        "Translate-next.hover.enable": {
          "type": "boolean",
          "default": true,
          "description": "%config.hover.enable.description%",
          "order": 3
        },
        "Translate-next.hover.extensions": {
          "type": "string",
          "default": "js,jsx,ts,tsx,java,py,c,h,cpp,cc,cxx,hpp,hh,hxx,rs,go,cs,php,rb,swift,kt,kts,scala,dart,lua",
          "description": "%config.hover.extensions.description%",
          "pattern": "^\\s*\\*\\s*$|^\\s*\\.?[A-Za-z0-9][A-Za-z0-9+_-]*\\s*(,\\s*\\.?[A-Za-z0-9][A-Za-z0-9+_-]*\\s*)*$",
          "patternErrorMessage": "%config.hover.extensions.patternErrorMessage%",
          "order": 3.1
        },
        "Translate-next.hover.string": {
          "type": "boolean",
          "default": false,
          "order": 4,
          "description": "%config.hover.string.description%"
        },
        "Translate-next.hover.variable": {
          "type": "boolean",
          "default": false,
          "order": 5,
          "description": "%config.hover.variable.description%"
        },
        "Translate-next.hover.prompt": {
          "type": "boolean",
          "default": true,
          "order": 6,
          "description": "%config.hover.prompt.description%"
        },
        "Translate-next.hover.comment": {
          "type": "boolean",
          "default": true,
          "order": 7,
          "description": "%config.hover.comment.description%"
        },
        "Translate-next.hover.diagnostics": {
          "type": "boolean",
          "default": true,
          "order": 8,
          "description": "%config.hover.diagnostics.description%"
        },
        "Translate-next.parentLanguage": {
          "type": "string",
          "default": "Chinese",
          "order": 9
        },
        "Translate-next.multiLineMerge": {
          "type": "boolean",
          "default": false,
          "order": 10,
          "description": "%config.multiLineMerge.description%"
        },
        "Translate-next.openOutputPanel": {
          "type": "boolean",
          "default": false,
          "order": 11,
          "description": "%config.openOutputPanel.description%"
        },
        "Translate-next.showTerminalSelectTranslateBar": {
          "type": "boolean",
          "default": true,
          "order": 12,
          "description": "%config.showTerminalSelectTranslateBar.description%"
        },
        "Translate-next.cacheTime": {
          "type": "number",
          "default": 600000,
          "description": "%config.cacheTime.description%",
          "order": 13
        },
        "Translate-next.optimize.concurrencyNum": {
          "type": "number",
          "default": 4,
          "description": "%config.optimize.concurrencyNum.description%",
          "order": 14
        },
        "Translate-next.optimize.requestGapDelay": {
          "type": "number",
          "default": 20,
          "description": "%config.optimize.requestGapDelay.description%",
          "order": 15
        },
        "Translate-next.optimize.enableLanguageDetect": {
          "type": "boolean",
          "default": false,
          "description": "%config.optimize.enableLanguageDetect.description%",
          "order": 16
        },
        "Translate-next.optimize.languageDetectSize": {
          "type": "number",
          "default": 200,
          "description": "%config.optimize.languageDetectSize.description%",
          "order": 17
        },
        "Translate-next.optimize.translateBatchSize": {
          "type": "number",
          "default": 500,
          "description": "%config.optimize.translateBatchSize.description%",
          "order": 18
        },
